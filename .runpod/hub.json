{
    "title": "GLM-OCR Full Pipeline",
    "description": "Self-hosted GLM-OCR on RunPod with the official PDF/layout pipeline, OpenAI-compatible raw OCR access, health/metrics endpoints, and model preloading for faster startup.",
    "type": "serverless",
    "category": "image",
    "config": {
        "runsOn": "GPU",
        "containerDiskInGb": 20,
        "gpuCount": 1,
        "gpuIds": "ADA_16,ADA_24,RTX A4000,RTX A5000,NVIDIA L4,NVIDIA RTX 4000 Ada Generation",
        "allowedCudaVersions": ["12.1", "12.4", "12.6"]
    },
    "env": [
        {
            "key": "MODEL_NAME",
            "input": {
                "type": "string",
                "name": "Model Name",
                "description": "HuggingFace model ID",
                "default": "zai-org/GLM-OCR",
                "advanced": true
            }
        },
        {
            "key": "SERVED_MODEL_NAME",
            "input": {
                "type": "string",
                "name": "Served Model Name",
                "description": "Model name exposed by vLLM",
                "default": "glm-ocr",
                "advanced": true
            }
        },
        {
            "key": "GPU_MEMORY_UTILIZATION",
            "input": {
                "type": "string",
                "name": "GPU Memory Utilization",
                "description": "Fraction of GPU memory to use (0.0 - 1.0)",
                "default": "0.95",
                "advanced": true
            }
        },
        {
            "key": "MAX_MODEL_LEN",
            "input": {
                "type": "string",
                "name": "Max Model Length",
                "description": "Maximum context length (leave empty for auto)",
                "default": "",
                "advanced": true
            }
        },
        {
            "key": "GLMOCR_LAYOUT_DEVICE",
            "input": {
                "type": "string",
                "name": "Layout Device",
                "description": "Use cpu to keep GPU RAM focused on OCR inference",
                "default": "cpu",
                "advanced": true
            }
        }
    ],
    "presets": [
        {
            "name": "Full PDF OCR",
            "defaults": {}
        },
        {
            "name": "Low-Latency Raw OCR",
            "defaults": {}
        }
    ]
}
